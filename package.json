    "phase3-api-test": "node test/phase3-api-test.js",
    "phase4-api-test": "node test/phase4-api-test.js",
    "phase4-smoke": "node test/phase4-test.js",
    "phase5-plugins-test": "node test/phase5-plugins-test.js",

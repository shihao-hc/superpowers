    "phase10-health-test": "node test/phase10-health-test.js",
    "phase10-health-trace": "node test/phase10-health-trace.js",
    "phase10-end-to-end-test": "node test/phase10-end-to-end-test.js",
    "phase10-run-all": "node test/phase10-run-all.js",
    "uw": "node scripts/uw.js",
    "uw:governance": "node scripts/uw.js phase11:governance",
    "uw:update": "node scripts/uw.js phase11:update",
    "uw:coord": "node scripts/uw.js phase12:coord",
    "uw:security": "node scripts/uw.js phase13:security",
    "uw:perf": "node scripts/uw.js phase14:perf",
    "uw:test": "node scripts/uw.js phase15:test",
    "uw:all": "node scripts/uw.js all",
    "security:monitor": "node scripts/security-monitor.js",
    "security:score": "node scripts/security-score.js",
    "security:audit": "npm run security:monitor && npm run security:score"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/server-brave-search": "^0.6.2",
    "@modelcontextprotocol/server-everything": "^2026.1.26",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.12.18",
    "@playwright/test": "^1.58.2",
    "jest": "^29.7.0",
    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  },

    "phase6-run-advanced": "node test/phase6-advanced-test.js",
    "phase7-health": "node test/phase7-health-test.js",
    "phase7-health-extended": "node test/phase7-health-extended.js",
    "phase8-ci-test": "node test/phase8-ci-test.js",
    "phase9-health-test": "node test/phase9-health-test.js",
    "phase9-health-extended": "node test/phase9-health-extended.js",
    "phase9-run-all": "node test/phase9-run-all.js",
    "phase9-end-to-end-test": "node test/phase9-end-to-end-test.js",

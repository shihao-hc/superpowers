{
  "name": "ultrawork-ai",
  "version": "1.0.0",
  "description": "UltraWork AI Platform - Multi-Agent AI Skill System",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "start:legacy": "node server/staticServer.js",
    "dev": "nodemon server/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:mcp": "playwright test tests/e2e/mcp-ui-simplified.spec.js",
    "test:mcp": "node test/mcp-integration-test.js",
    "test:mcp:integration": "node tests/integration/mcp-client.test.js",

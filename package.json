    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mineflayer": "^4.35.0",
    "mineflayer-pathfinder": "^2.4.5",
    "ollama": "^0.6.3",
    "otplib": "^13.4.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "three": "^0.183.2",
    "winston": "^3.19.0"
  }
}

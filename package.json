    "test:mcp:e2e": "playwright test tests/e2e/mcp-ui.spec.js",
    "mcp:start": "node scripts/mcp-integration.js",
    "mcp:agent": "node examples/mcp/mcp-agent-example.js",
    "mcp:workflow": "node examples/mcp/mcp-workflow-example.js",
    "mcp:log-workflow": "node examples/mcp/mcp-log-analysis-workflow.js",
    "learn-eval": "node -e \"require('./src/learnEval').run()\"",
    "serve-frontend": "node server/staticServer.js",
    "start-prod": "NODE_ENV=production node server/staticServer.js",

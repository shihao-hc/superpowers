    "/api/v1/intent/multimodal": {
      "post": {
        "operationId": "understandMultimodal",
        "summary": "Understand multimodal content",
        "description": "Analyze images, audio, video, or documents and extract intent",
        "tags": [
          "Intent"
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "image",
                      "audio",
                      "video",
                      "document"
                    ]
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "caption": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {

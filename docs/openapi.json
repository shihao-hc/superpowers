              "type": "string",
              "enum": [
                "daily",
                "weekly",
                "monthly"
              ]
            }
          },
          {
            "name": "granularity",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "hourly",
                "daily",
                "weekly"
              ]
            }
          }
        ],
        "responses": {

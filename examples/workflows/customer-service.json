{
  "name": "智能客服工作流",
  "description": "接收用户问题 → 检索知识库 → 生成回复 → 多渠道发送",
  "category": "customer_service",
  "tags": ["客服", "AI", "问答"],
  "author": "UltraWork 官方",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "input_question",
      "type": "input",
      "name": "用户问题",
      "icon": "📥",
      "x": 100, "y": 150,
      "inputs": [],
      "outputs": [{ "name": "value", "type": "string" }]
    },
    {
      "id": "intent_detect",
      "type": "llm_call",
      "name": "意图识别",
      "icon": "🧠",
      "x": 300, "y": 150,
      "inputs": [{ "name": "prompt", "type": "string" }],
      "outputs": [{ "name": "response", "type": "string" }]
    },
    {
      "id": "generate_answer",
      "type": "llm_call",
      "name": "生成回复",
      "icon": "💬",
      "x": 500, "y": 150,
      "inputs": [{ "name": "prompt", "type": "string" }],
      "outputs": [{ "name": "response", "type": "string" }]
    },
    {
      "id": "send_response",
      "type": "notify",
      "name": "发送回复",
      "icon": "📤",
      "x": 700, "y": 150,
      "inputs": [{ "name": "title", "type": "string" }, { "name": "body", "type": "string" }],
      "outputs": [{ "name": "sent", "type": "boolean" }]
    }
  ],
  "connections": [
    { "source": { "nodeId": "input_question", "output": "value" }, "target": { "nodeId": "intent_detect", "input": "prompt" } },
    { "source": { "nodeId": "intent_detect", "output": "response" }, "target": { "nodeId": "generate_answer", "input": "prompt" } },
    { "source": { "nodeId": "generate_answer", "output": "response" }, "target": { "nodeId": "send_response", "input": "body" } }
  ]
}
